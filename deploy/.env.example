# Copy to deploy/.env and replace every CHANGE_ME value before first start.
AUTOSCRIPT_SERVER_IMAGE=ghcr.io/czf39631/autoscript-hub-server:0.9.0
# Docker Hub is the default. In networks where Docker Hub is unreachable, use a
# compatible proxy such as docker.m.daocloud.io/library without changing daemon settings.
AUTOSCRIPT_BASE_REGISTRY=docker.io/library
AUTOSCRIPT_BIND_ADDRESS=0.0.0.0
AUTOSCRIPT_PORT=8000
AUTOSCRIPT_DATA_DIR=/opt/autoscript-hub/data
AUTOSCRIPT_UID=1000
AUTOSCRIPT_GID=1000
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_BEFORE_FIRST_START
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
LOG_ARCHIVE_RETENTION_DAYS=90
# Same-origin web use needs no CORS entry. Separate origins are comma-separated.
CORS_ORIGINS=
